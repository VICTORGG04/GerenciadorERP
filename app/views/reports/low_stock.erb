<!-- views/reports/low_stock.erb -->
<div class="page-header">
  <h1>Relatório de Estoque Mínimo</h1>
  <div style="display:flex;gap:8px">
    <a href="/reports/low_stock.csv" class="btn btn-ghost">⬇ Exportar CSV</a>
    <a href="/reports" class="btn btn-ghost">← Relatórios</a>
  </div>
</div>

<% if @products.empty? %>
  <div class="card" style="text-align:center;padding:40px;color:#059669">
    <div style="font-size:40px;margin-bottom:10px">✓</div>
    <div style="font-weight:700;font-size:18px">Tudo em ordem!</div>
    <div style="font-size:14px;color:#888;margin-top:6px">
      Nenhum produto abaixo do estoque mínimo.
    </div>
  </div>
<% else %>
  <div style="font-size:13px;margin-bottom:12px">
    <span style="background:#fee2e2;color:#991b1b;padding:4px 12px;border-radius:12px;font-weight:700">
      ⚠ <%= @products.size %> produto(s) precisam de atenção
    </span>
  </div>

  <div class="card">
    <!-- Header -->
    <div style="display:grid;grid-template-columns:2fr 1fr 1fr 80px 80px 100px;
                gap:8px;padding:8px 0;border-bottom:2px solid #e2e8f0;
                font-size:12px;font-weight:700;color:#888;text-transform:uppercase">
      <div>Produto</div>
      <div>SKU</div>
      <div>Categoria</div>
      <div style="text-align:center">Atual</div>
      <div style="text-align:center">Mínimo</div>
      <div style="text-align:center">Status</div>
    </div>

    <% @products.each do |p| %>
      <div style="display:grid;grid-template-columns:2fr 1fr 1fr 80px 80px 100px;
                  gap:8px;padding:12px 0;border-bottom:1px solid #f0f0f0;align-items:center">
        <div>
          <a href="/products/<%= p.id %>" style="font-weight:600;color:#1e293b;text-decoration:none">
            <%= h(p.name) %>
          </a>
        </div>
        <div style="font-size:13px;color:#888"><%= h(p.sku) %></div>
        <div style="font-size:13px;color:#555"><%= h(p.category_name.to_s) %></div>
        <div style="text-align:center;font-weight:700;
                    color:<%= p.out_of_stock? ? '#dc2626' : '#f59e0b' %>">
          <%= p.quantity %>
        </div>
        <div style="text-align:center;color:#888"><%= p.min_quantity %></div>
        <div style="text-align:center">
          <span style="background:<%= p.out_of_stock? ? '#fee2e2' : '#fef3c7' %>;
                       color:<%= p.out_of_stock? ? '#991b1b' : '#92400e' %>;
                       padding:3px 8px;border-radius:12px;font-size:11px;font-weight:700">
            <%= p.out_of_stock? ? 'SEM ESTOQUE' : 'BAIXO' %>
          </span>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
