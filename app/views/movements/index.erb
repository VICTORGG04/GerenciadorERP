<!-- views/movements/index.erb -->
<div class="page-header">
  <h1>Movimentações</h1>
  <a href="/products" class="btn btn-ghost">← Produtos</a>
</div>

<% if @movements.empty? %>
  <div class="empty-state">Nenhuma movimentação registrada.</div>
<% else %>
  <div class="card">
    <% @movements.each do |m| %>
      <div class="list-row" style="display:flex;align-items:center;gap:14px;padding:10px 0;border-bottom:1px solid #f0f0f0">

        <span class="badge <%= h(m.kind) %>"
              style="min-width:60px;text-align:center;padding:4px 8px;border-radius:6px;font-size:12px;font-weight:700;
                     background:<%= m.kind=='in' ? '#d1fae5' : m.kind=='out' ? '#fee2e2' : '#fef3c7' %>;
                     color:<%= m.kind=='in' ? '#065f46' : m.kind=='out' ? '#991b1b' : '#92400e' %>">
          <%= m.kind.upcase %>
        </span>

        <div style="flex:1">
          <strong><%= h(m.product_name) %></strong>
          <div style="font-size:12px;color:#888"><%= h(m.product_sku.to_s) %></div>
        </div>

        <div style="flex:1;color:#666;font-size:13px">
          <%= h(m.reason.to_s.empty? ? '—' : m.reason) %>
        </div>

        <div style="text-align:right">
          <strong style="color:<%= m.kind=='out' ? '#dc2626' : '#059669' %>">
            <%= m.kind == 'out' ? '-' : '+' %><%= m.quantity %>
          </strong>
          <div style="font-size:11px;color:#aaa">
            <%= m.created_at.to_s[0, 16].gsub('T', ' ') %>
          </div>
        </div>

      </div>
    <% end %>
  </div>
<% end %>
