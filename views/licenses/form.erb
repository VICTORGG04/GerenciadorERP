<div class="page-header">
  <h1>Nova Licença</h1>
  <a href="/licenses" class="btn btn-ghost">← Voltar</a>
</div>

<% if @error %>
  <div class="alert alert-error"><%= @error %></div>
<% end %>

<form method="post" action="/licenses" style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start">
  <div class="card">
    <div class="card-title">📋 Dados da Licença</div>
    <div style="display:flex;flex-direction:column;gap:14px">
      <div>
        <label class="label">Plano *</label>
        <select class="input" name="plan" required>
          <option value="">Selecione...</option>
          <% License::PLANOS.each do |p| %>
            <option value="<%= p %>" <%= @license && @license[:plan] == p ? 'selected' : '' %>><%= p.capitalize %></option>
          <% end %>
        </select>
      </div>
      <div>
        <label class="label">Dias de validade *</label>
        <input class="input" type="number" name="days" value="365" min="1" required>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">🏢 Empresa</div>
    <div style="display:flex;flex-direction:column;gap:14px">
      <div>
        <label class="label">Razão Social *</label>
        <input class="input" name="company_name" value="<%= @license&.company_name %>" required placeholder="Nome da empresa">
      </div>
      <div>
        <label class="label">CNPJ</label>
        <input class="input" name="cnpj" value="<%= @license&.cnpj %>" placeholder="00.000.000/0001-00">
      </div>
    </div>
  </div>

  <div class="card" style="grid-column:1/-1">
    <div class="card-title">📍 Endereço</div>
    <div style="display:grid;grid-template-columns:1fr 120px 1fr;gap:14px">
      <div>
        <label class="label">Logradouro</label>
        <input class="input" name="address_street" value="<%= @license&.address_street %>" placeholder="Rua, Av...">
      </div>
      <div>
        <label class="label">Número</label>
        <input class="input" name="address_number" value="<%= @license&.address_number %>" placeholder="Nº">
      </div>
      <div>
        <label class="label">Complemento</label>
        <input class="input" name="address_complement" value="<%= @license&.address_complement %>" placeholder="Sala, Andar...">
      </div>
      <div>
        <label class="label">Bairro</label>
        <input class="input" name="address_neighborhood" value="<%= @license&.address_neighborhood %>">
      </div>
      <div>
        <label class="label">Cidade</label>
        <input class="input" name="address_city" value="<%= @license&.address_city %>">
      </div>
      <div>
        <label class="label">Estado</label>
        <input class="input" name="address_state" value="<%= @license&.address_state %>" maxlength="2" placeholder="UF">
      </div>
      <div>
        <label class="label">CEP</label>
        <input class="input" name="address_zip" value="<%= @license&.address_zip %>" placeholder="00000-000">
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">📞 Contato</div>
    <div style="display:flex;flex-direction:column;gap:14px">
      <div>
        <label class="label">Nome do contato</label>
        <input class="input" name="contact_name" value="<%= @license&.contact_name %>">
      </div>
      <div>
        <label class="label">E-mail</label>
        <input class="input" type="email" name="contact_email" value="<%= @license&.contact_email %>">
      </div>
      <div>
        <label class="label">Telefone</label>
        <input class="input" name="contact_phone" value="<%= @license&.contact_phone %>" placeholder="(00) 00000-0000">
      </div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">📝 Observações</div>
    <div>
      <textarea class="input" name="notes" rows="6" placeholder="Informações adicionais..."><%= @license&.notes %></textarea>
    </div>
  </div>

  <div style="grid-column:1/-1;display:flex;gap:12px;justify-content:flex-end">
    <a href="/licenses" class="btn btn-ghost">Cancelar</a>
    <button class="btn btn-primary" type="submit">✨ Gerar Licença</button>
  </div>
</form>
