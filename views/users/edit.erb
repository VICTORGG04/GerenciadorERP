<!-- views/users/edit.erb -->
<div class="page-header">
  <h1>Editar Usuário</h1>
  <a href="/users" class="btn btn-ghost">← Voltar</a>
</div>

<% if @error %>
  <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:16px">
    ⚠ <%= h(@error) %>
  </div>
<% end %>

<div class="card" style="max-width:500px">
  <form method="post" action="/users/<%= @user.id %>" style="display:flex;flex-direction:column;gap:14px">
    <input type="hidden" name="_method" value="patch">

    <div>
      <label class="label">Nome *</label>
      <input class="input" name="name" required placeholder="Nome completo"
             value="<%= h(@form_params&.dig('name') || @user.name) %>">
    </div>

    <div>
      <label class="label">E-mail *</label>
      <input class="input" type="email" name="email" required placeholder="usuario@email.com"
             value="<%= h(@form_params&.dig('email') || @user.email) %>">
    </div>

    <div>
      <label class="label">Nível de acesso *</label>
      <select class="input" name="role" required>
        <% User::ROLES.each do |value, label| %>
          <option value="<%= value %>"
            <%= 'selected' if (@form_params&.dig('role') || @user.role) == value %>>
            <%= label %>
          </option>
        <% end %>
      </select>
    </div>

    <div style="display:flex;gap:10px;justify-content:flex-end;margin-top:8px">
      <a href="/users" class="btn btn-ghost">Cancelar</a>
      <button class="btn btn-primary" type="submit">Salvar Alterações</button>
    </div>

  </form>
</div>
