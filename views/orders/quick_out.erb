<!-- views/order.rb/quick_out.erb -->
<div class="page-header">
  <h1>⚡ Baixa Rápida</h1>
  <a href="/orders" class="btn btn-ghost">← Pedidos</a>
</div>

<% if params[:ok] %>
  <div style="background:#d1fae5;color:#065f46;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-weight:500">
    ✓ Baixa registrada com sucesso! Estoque atualizado.
  </div>
<% end %>

<% if @error %>
  <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-weight:500">
    ⚠ <%= h(@error) %>
  </div>
<% end %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start">

  <!-- Formulário -->
  <div class="card">
    <div class="card-title" style="margin-bottom:14px">Registrar Saída</div>

    <form method="post" action="/quick_out" style="display:flex;flex-direction:column;gap:14px">

      <div>
        <label class="label">Produto *</label>
        <select class="input" name="product_id" required onchange="updateStock(this)">
          <option value="">— Selecione —</option>
          <% @products.each do |p| %>
            <option value="<%= p.id %>"
                    data-stock="<%= p.quantity %>"
                    data-min="<%= p.min_quantity %>"
                    <%= p.out_of_stock? ? 'disabled' : '' %>>
              <%= h(p.name) %> — estoque: <%= p.quantity %> <%= p.out_of_stock? ? '(SEM ESTOQUE)' : '' %>
            </option>
          <% end %>
        </select>
        <div id="stock-info" style="font-size:12px;color:#888;margin-top:4px"></div>
      </div>

      <div>
        <label class="label">Quantidade *</label>
        <input class="input" type="number" name="quantity" min="1" value="1" required id="qty-input">
      </div>

      <div>
        <label class="label">Motivo *</label>
        <input class="input" name="reason" required placeholder="Ex: Venda balcão, Uso interno, Brinde...">
      </div>

      <button class="btn btn-primary" type="submit"
              onclick="return confirm('Confirmar baixa de estoque?')">
        ⬇ Registrar Baixa
      </button>

    </form>
  </div>

  <!-- Info / dica -->
  <div>
    <div class="card" style="border-left:4px solid #6366f1">
      <div style="font-weight:600;margin-bottom:8px">Como funciona a Baixa Rápida?</div>
      <div style="font-size:14px;color:#555;line-height:1.6">
        <p>Use para saídas simples e imediatas, como:</p>
        <ul style="padding-left:18px;margin:8px 0">
          <li>Venda no balcão</li>
          <li>Uso interno / consumo</li>
          <li>Brindes ou amostras</li>
          <li>Perda ou avaria</li>
        </ul>
        <p>A saída é registrada imediatamente em <strong>Movimentações</strong> com referência automática.</p>
        <p style="margin-top:8px">Para vendas com múltiplos itens e cliente, use
          <a href="/orders/new" style="color:#6366f1">Pedido de Venda</a>.
        </p>
      </div>
    </div>
  </div>

</div>

<script>
function updateStock(select) {
  const opt   = select.options[select.selectedIndex];
  const stock = opt.dataset.stock;
  const info  = document.getElementById('stock-info');
  const qty   = document.getElementById('qty-input');

  if (stock !== undefined) {
    info.textContent = `Disponível: ${stock} unidade(s)`;
    info.style.color = stock > 0 ? '#059669' : '#dc2626';
    qty.max = stock;
  } else {
    info.textContent = '';
  }
}
</script>
