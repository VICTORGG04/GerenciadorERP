<!-- views/backups.erb -->
<div class="page-header">
  <h1>Backups</h1>
  <form method="post" action="/backups/create">
    <button class="btn btn-primary" type="submit">⬇ Gerar Backup Agora</button>
  </form>
</div>

<% if params[:ok] %>
  <div style="background:#d1fae5;color:#065f46;padding:10px 16px;border-radius:8px;margin-bottom:16px">
    ✓ <%= params[:ok] %>
  </div>
<% end %>

<% if @backup_files.empty? %>
  <div class="empty-state">Nenhum backup gerado ainda. Clique em "Gerar Backup Agora".</div>
<% else %>
  <div class="card">
    <% @backup_files.each do |filename| %>
      <div style="display:flex;align-items:center;justify-content:space-between;
                  padding:10px 0;border-bottom:1px solid #f0f0f0">

        <div style="display:flex;align-items:center;gap:10px">
          <span style="font-size:20px">📄</span>
          <span style="font-family:monospace;font-size:13px"><%= filename %></span>
        </div>

        <div style="display:flex;gap:8px">
          <a href="/backups/download/<%= filename %>" class="btn btn-sm btn-ghost">
            ⬇ Download
          </a>
          <form method="post" action="/backups/delete/<%= filename %>"
                onsubmit="return confirm('Excluir este backup?')">
            <button class="btn btn-sm btn-danger" type="submit">🗑</button>
          </form>
        </div>

      </div>
    <% end %>
  </div>
<% end %>
