<div class="page-header">
  <h1>Produtos</h1>
  <div style="display:flex;gap:8px">
    <a href="/products/new" class="btn btn-primary">+ Novo Produto</a>
    <a href="/" class="btn btn-ghost">← Dashboard</a>
  </div>
</div>

<% if @error %>
  <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-weight:500">
    ⚠ <%= @error %>
  </div>
<% end %>

<% if @products.empty? %>
  <div class="empty-state">Nenhum produto cadastrado.</div>
<% else %>
  <div style="display:flex;flex-direction:column;gap:8px">
    <% @products.each do |p| %>
      <div class="product-card" style="<%= p.out_of_stock? ? 'border-left:3px solid #ef4444;' : p.low_stock? ? 'border-left:3px solid #f59e0b;' : 'border-left:3px solid #10b981;' %>">
        <div class="product-info">
          <div class="product-name">
            <a href="/products/<%= p.id %>" style="color:inherit;text-decoration:none"><%= h(p.name) %></a>
          </div>
          <span class="product-sku"><%= h(p.sku) %></span>
          <% if p.category_name %>
            <span class="text-muted" style="margin-left:6px;font-size:11px">— <%= h(p.category_name) %></span>
          <% end %>
        </div>
        <div class="product-stats">
          <div class="stat-box">
            <div class="stat-value" style="color:<%= p.out_of_stock? ? '#ef4444' : p.low_stock? ? '#f59e0b' : '#10b981' %>">
              <%= p.quantity %>
            </div>
            <div class="stat-label"><%= h(p.unit) %></div>
          </div>
          <div class="stat-box">
            <div class="stat-value"><%= fmt_brl(p.price) %></div>
            <div class="stat-label">Preço</div>
          </div>
          <% if p.min_quantity > 0 %>
            <div class="stat-box">
              <div class="stat-value" style="font-size:14px"><%= p.min_quantity %></div>
              <div class="stat-label">Mínimo</div>
            </div>
          <% end %>
          <span class="pill <%= p.out_of_stock? ? 'pill-red' : p.low_stock? ? 'pill-yellow' : 'pill-green' %>">
            <%= p.out_of_stock? ? 'SEM ESTOQUE' : p.low_stock? ? 'ESTOQUE BAIXO' : 'OK' %>
          </span>
          <div style="display:flex;gap:4px">
            <a href="/products/<%= p.id %>" class="btn btn-sm btn-ghost">Ver</a>
            <a href="/products/<%= p.id %>/edit" class="btn btn-sm btn-ghost">✏️</a>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
