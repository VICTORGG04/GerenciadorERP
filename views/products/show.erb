<div class="page-header">
  <div>
    <h1><%= h(@product.name) %></h1>
    <span class="product-sku"><%= h(@product.sku) %></span>
  </div>
  <div style="display:flex;gap:8px">
    <a href="/products/<%= @product.id %>/edit" class="btn btn-ghost">✏️ Editar</a>
    <a href="/products" class="btn btn-ghost">← Voltar</a>
  </div>
</div>

<div class="kpi-grid">
  <div class="kpi-card" style="--accent:<%= @product.out_of_stock? ? '#ef4444' : @product.low_stock? ? '#f59e0b' : '#10b981' %>">
    <div class="kpi-value"><%= @product.quantity %></div>
    <div class="kpi-label">Em Estoque (<%= h(@product.unit) %>)</div>
  </div>
  <div class="kpi-card" style="--accent:#6366f1">
    <div class="kpi-value"><%= fmt_brl(@product.price) %></div>
    <div class="kpi-label">Preço de Venda</div>
  </div>
  <div class="kpi-card" style="--accent:#10b981">
    <div class="kpi-value"><%= fmt_brl(@product.total_value) %></div>
    <div class="kpi-label">Valor Total em Estoque</div>
  </div>
  <% if @product.profit_margin %>
    <div class="kpi-card" style="--accent:#06b6d4">
      <div class="kpi-value"><%= @product.profit_margin %>%</div>
      <div class="kpi-label">Margem de Lucro</div>
    </div>
  <% end %>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
  <div class="card">
    <div class="card-title">▲ Adicionar Estoque</div>
    <form method="post" action="/products/<%= @product.id %>/add_stock" style="display:flex;flex-direction:column;gap:10px">
      <input class="input" type="number" name="quantity" placeholder="Quantidade" min="1" required>
      <input class="input" type="text"   name="reason"   placeholder="Motivo (ex: Compra NF-001)">
      <input class="input" type="text"   name="reference" placeholder="Referência (opcional)">
      <button class="btn btn-success" type="submit">Confirmar Entrada</button>
    </form>
  </div>
  <div class="card">
    <div class="card-title">▼ Remover Estoque</div>
    <form method="post" action="/products/<%= @product.id %>/remove_stock" style="display:flex;flex-direction:column;gap:10px">
      <input class="input" type="number" name="quantity" placeholder="Quantidade" min="1" max="<%= @product.quantity %>" required>
      <input class="input" type="text"   name="reason"   placeholder="Motivo (ex: Venda PED-123)">
      <input class="input" type="text"   name="reference" placeholder="Referência (opcional)">
      <button class="btn btn-danger" type="submit">Confirmar Saída</button>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-title">⟳ Ajuste de Inventário</div>
  <form method="post" action="/products/<%= @product.id %>/adjust" style="display:flex;gap:10px;flex-wrap:wrap">
    <input class="input" type="number" name="quantity" placeholder="Nova quantidade real" min="0" required style="flex:1">
    <input class="input" type="text"   name="reason"  placeholder="Motivo do ajuste"              style="flex:2">
    <button class="btn btn-warning" type="submit">Ajustar</button>
  </form>
</div>

  <!-- ── Ações de risco ────────────────────────────────────── -->
  <div style="margin-top:20px;padding-top:20px;border-top:1px solid var(--border,#eee);display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap">
    <form method="post" action="/products/<%= @product.id %>/zero_stock"
          onsubmit="return confirm('Zerar o estoque de <%= h(@product.name) %>? O produto continuará cadastrado com quantidade 0.')">
      <input type="hidden" name="reason" value="Zerado manualmente pelo administrador">
      <button class="btn btn-warning" type="submit">📦 Zerar Estoque</button>
    </form>
    <form method="post" action="/products/<%= @product.id %>/delete"
          onsubmit="return confirm('Excluir permanentemente <%= h(@product.name) %>?\n\nTodas as movimentações deste produto serão removidas.')">
      <button class="btn btn-danger" type="submit">🗑 Excluir Produto</button>
    </form>
  </div>

  <!-- Histórico de Movimentações (Auditoria) -->
  <div style="margin-top:28px">
    <div style="font-weight:700;font-size:16px;color:#1e293b;margin-bottom:12px;
      display:flex;justify-content:space-between;align-items:center">
      <span>📋 Histórico de Movimentações</span>
      <span style="font-size:13px;font-weight:400;color:#888">
        <%= @audit.size %> registro(s)
      </span>
    </div>

    <% if @audit.empty? %>
      <div style="background:#f8fafc;border-radius:10px;padding:24px;text-align:center;color:#888;font-size:14px">
        Nenhuma movimentação registrada para este produto.
      </div>
    <% else %>
      <div class="card" style="padding:0">
        <% @audit.each do |m| %>
          <div style="display:flex;align-items:center;gap:12px;padding:10px 16px;border-bottom:1px solid #f0f0f0">

          <span style="min-width:64px;text-align:center;padding:3px 8px;border-radius:6px;
            font-size:11px;font-weight:700;
            background:<%= m.kind=='in' ? '#d1fae5' : m.kind=='out' ? '#fee2e2' : '#fef3c7' %>;
            color:<%= m.kind=='in' ? '#065f46' : m.kind=='out' ? '#991b1b' : '#92400e' %>">
            <%= m.kind == 'in' ? 'ENTRADA' : m.kind == 'out' ? 'SAÍDA' : 'AJUSTE' %>
          </span>

            <div style="flex:1;font-size:14px;color:#555">
              <%= h(m.reason.to_s.empty? ? '—' : m.reason) %>
            </div>

            <div style="font-size:12px;color:#aaa;min-width:120px">
              <%= h(m.reference.to_s) %>
            </div>

            <div style="font-weight:700;min-width:50px;text-align:right;
              color:<%= m.kind=='out' ? '#dc2626' : '#059669' %>">
              <%= m.kind == 'out' ? '-' : '+' %><%= m.quantity %>
            </div>

            <div style="font-size:11px;color:#bbb;min-width:120px;text-align:right">
              <%= m.created_at.to_s[0,16].gsub('T',' ') %>
            </div>

          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div>