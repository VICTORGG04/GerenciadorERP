# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=gerenciador_estoque
DB_USER=gerenciador_erp
DB_PASSWORD=CHANGE_ME

# ── Sessão ─────────────────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_ME

# ── Servidor interno (Sinatra/Puma) ────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=4568
APP_ENV=production

# ── Domínio público (para HTTPS via Caddy) ─────────────────────────────────────
# Deixe vazio para usar localhost com certificado auto-assinado.
# Exemplo: APP_DOMAIN=meusistema.com.br
APP_DOMAIN=

# ── Licença ───────────────────────────────────────────────────────────────────
# Token de licença HMAC. Se vazio ou inválido, o sistema roda como FREE.
# Para gerar um token: ruby gerar_licenca.rb <plano>
# Planos: free | gold | platinum | enterprise
LICENSE_TOKEN=

# ── Google Sheets (validação online de licenças) ──────────────────────────────
# ID da planilha (extraído da URL: https://docs.google.com/spreadsheets/d/<ID>/edit)
# GOOGLE_SHEET_ID=
# Caminho absoluto para o JSON da service account do Google Cloud
# GOOGLE_SHEET_CREDENTIALS=/etc/gerenciador-erp/chave-google-sheets.json

# ── Backup automático ──────────────────────────────────────────────────────────
BACKUP_TIME=23:00
BACKUP_DIR=/var/lib/gerenciador-erp/backups
BACKUP_RETENTION_DAYS=30

# ── Stripe (pagamentos) ───────────────────────────────────────────────────────
# Chaves da API Stripe (https://dashboard.stripe.com/apikeys)
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Webhook secret (https://dashboard.stripe.com/webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Prices Stripe (criados via scripts/setup_stripe_prices.rb)
# STRIPE_PRICE_GOLD_MONTHLY=price_xxx
# STRIPE_PRICE_GOLD_SEMIANNUAL=price_xxx
# STRIPE_PRICE_GOLD_LIFETIME=price_xxx
# STRIPE_PRICE_PLATINUM_MONTHLY=price_xxx
# STRIPE_PRICE_PLATINUM_SEMIANNUAL=price_xxx
# STRIPE_PRICE_PLATINUM_LIFETIME=price_xxx
# STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
# STRIPE_PRICE_ENTERPRISE_SEMIANNUAL=price_xxx
# STRIPE_PRICE_ENTERPRISE_LIFETIME=price_xxx
