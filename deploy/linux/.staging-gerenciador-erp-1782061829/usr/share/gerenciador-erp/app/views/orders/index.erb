<!-- views/order.rb/index.erb -->
<div class="page-header">
  <h1>Pedidos de Venda</h1>
  <div style="display:flex;gap:8px">
    <a href="/quick_out" class="btn btn-ghost">⚡ Baixa Rápida</a>
    <a href="/orders/new" class="btn btn-primary">+ Novo Pedido</a>
  </div>
</div>

<% if @orders.empty? %>
  <div class="empty-state">Nenhum pedido registrado.</div>
<% else %>
  <div class="card">
    <% @orders.each do |o| %>
      <%
        status_bg    = o.confirmed? ? '#d1fae5' : o.cancelled? ? '#fee2e2' : '#fef3c7'
        status_color = o.confirmed? ? '#065f46' : o.cancelled? ? '#991b1b' : '#92400e'
        status_label = o.confirmed? ? 'Confirmado' : o.cancelled? ? 'Cancelado' : 'Pendente'
      %>
      <div style="display:flex;align-items:center;gap:14px;padding:12px 0;border-bottom:1px solid #f0f0f0">

        <div style="min-width:160px">
          <a href="/orders/<%= o.id %>" style="font-weight:600;color:#6366f1;text-decoration:none">
            <%= h(o.reference) %>
          </a>
          <div style="font-size:12px;color:#888"><%= o.created_at.to_s[0,16].gsub('T',' ') %></div>
        </div>

        <div style="flex:1;font-size:14px;color:#555">
          <%= h(o.customer.to_s.empty? ? '— sem cliente —' : o.customer) %>
        </div>

        <span style="background:<%= status_bg %>;color:<%= status_color %>;
                     padding:3px 10px;border-radius:12px;font-size:12px;font-weight:700">
          <%= status_label %>
        </span>

        <div style="text-align:right;min-width:100px;font-weight:600">
          <%= fmt_brl(o.total) %>
        </div>

        <a href="/orders/<%= o.id %>" class="btn btn-sm btn-ghost">Ver</a>
      </div>
    <% end %>
  </div>
<% end %>
