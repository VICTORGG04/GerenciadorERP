<!-- views/import/index.erb -->
<div class="page-header">
  <div>
    <h1 class="page-title">📥 Importar Produtos</h1>
    <p class="page-subtitle">Importe múltiplos produtos via planilha Excel ou CSV</p>
  </div>
  <a href="/import/template" class="btn btn-secondary">
    ⬇️ Baixar modelo CSV
  </a>
</div>

<div class="grid grid-2">

  <!-- Formulário de upload -->
  <div class="card">
    <h3 class="card-title">📂 Enviar Planilha</h3>

    <form method="POST" action="/import" enctype="multipart/form-data">
      <div class="form-group">
        <label class="form-label">Arquivo <span class="required">*</span></label>
        <input type="file"
               name="file"
               class="form-control"
               accept=".xlsx,.xls,.csv,.ods"
               required>
        <small class="form-hint">Formatos aceitos: .xlsx, .xls, .csv, .ods</small>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">
          📥 Importar Produtos
        </button>
      </div>
    </form>
  </div>

  <!-- Instruções -->
  <div class="card">
    <h3 class="card-title">📋 Instruções</h3>

    <p style="color:var(--muted);margin-bottom:1rem;font-size:0.9rem">
      A primeira linha da planilha deve conter os cabeçalhos. As colunas em
      <strong>negrito</strong> são obrigatórias.
    </p>

    <table class="table table-sm">
      <thead>
        <tr>
          <th>Coluna</th>
          <th>Obrigatório</th>
          <th>Exemplo</th>
        </tr>
      </thead>
      <tbody>
        <tr><td><strong>nome</strong></td><td>✔️</td><td>HD 1TB</td></tr>
        <tr><td><strong>preco</strong></td><td>✔️</td><td>299.90</td></tr>
        <tr><td><strong>custo</strong></td><td>✔️</td><td>180.00</td></tr>
        <tr><td><strong>quantidade</strong></td><td>✔️</td><td>10</td></tr>
        <tr><td>sku</td><td>Não</td><td>HD-1TB-001</td></tr>
        <tr><td>categoria</td><td>Não</td><td>Armazenamento</td></tr>
        <tr><td>quantidade_minima</td><td>Não</td><td>2</td></tr>
        <tr><td>unidade</td><td>Não</td><td>un</td></tr>
        <tr><td>descricao</td><td>Não</td><td>HD interno SATA</td></tr>
      </tbody>
    </table>

    <div class="alert alert-info mt-3" style="font-size:0.85rem">
      💡 Para CSV, use <strong>ponto-e-vírgula (;)</strong> ou <strong>vírgula (,)</strong> como separador.<br>
      Para preços, use ponto ou vírgula como decimal. Ex: <code>99.90</code> ou <code>99,90</code>
    </div>
  </div>

</div>
