<div class="page-header">
  <h1>Licenças de Clientes</h1>
  <a href="/licenses/new" class="btn btn-primary">+ Nova Licença</a>
</div>

<% if @licenses.empty? %>
  <div class="card" style="text-align:center;padding:48px">
    <div style="font-size:40px;margin-bottom:12px">🔑</div>
    <div class="empty-msg">Nenhuma licença cadastrada.</div>
    <a href="/licenses/new" class="btn btn-primary" style="margin-top:16px">+ Criar Primeira Licença</a>
  </div>
<% else %>
  <div class="card" style="padding:0">
    <table class="data-table">
      <thead>
        <tr>
          <th>Ref</th>
          <th>Empresa</th>
          <th>CNPJ</th>
          <th>Plano</th>
          <th>Status</th>
          <th>Expira</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @licenses.each do |l| %>
          <tr>
            <td><code><%= h(l.license_ref) %></code></td>
            <td><%= h(l.company_name) %></td>
            <td><%= h(l.cnpj) if l.cnpj %></td>
            <td><span class="badge" style="background:<%= plan_color(l.plan) %>;color:#fff"><%= l.plan_label %></span></td>
            <td><span class="pill <%= l.status_pill %>"><%= l.status_label %></span></td>
            <td style="color:var(--muted);font-size:12px"><%= l.expires_at_fmt %></td>
            <td>
              <div class="row-right">
                <a href="/licenses/<%= l.id %>" class="btn btn-sm btn-ghost">🔍</a>
                <form method="post" action="/licenses/<%= l.id %>"
                      onsubmit="return confirm('Excluir licença <%= h(l.license_ref) %> — <%= h(l.company_name) %>?')">
                  <input type="hidden" name="_method" value="delete">
                  <button class="btn btn-sm btn-danger" type="submit">🗑</button>
                </form>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
