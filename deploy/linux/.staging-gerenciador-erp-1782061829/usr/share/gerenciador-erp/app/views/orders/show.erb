<!-- views/order.rb/show.erb -->
<%
  status_bg    = @order.confirmed? ? '#d1fae5' : @order.cancelled? ? '#fee2e2' : '#fef3c7'
  status_color = @order.confirmed? ? '#065f46' : @order.cancelled? ? '#991b1b' : '#92400e'
  status_label = @order.confirmed? ? 'Confirmado' : @order.cancelled? ? 'Cancelado' : 'Pendente'
%>

<div class="page-header">
  <div>
    <h1><%= h(@order.reference) %></h1>
    <span style="background:<%= status_bg %>;color:<%= status_color %>;
                 padding:4px 12px;border-radius:12px;font-size:13px;font-weight:700">
      <%= status_label %>
    </span>
  </div>
  <a href="/orders" class="btn btn-ghost">← Pedidos</a>
</div>

<% if @error %>
  <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-weight:500">
    ⚠ <%= h(@error) %>
  </div>
<% end %>

<div style="display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start">

  <!-- Itens -->
  <div class="card">
    <div class="card-title" style="margin-bottom:12px">Itens do Pedido</div>

    <% @order.items.each do |item| %>
      <div style="display:grid;grid-template-columns:1fr 60px 110px 110px;
                  gap:8px;padding:10px 0;border-bottom:1px solid #f0f0f0;align-items:center">
        <div>
          <div style="font-weight:600"><%= h(item.product_name) %></div>
          <div style="font-size:12px;color:#888">SKU: <%= h(item.product_sku) %></div>
        </div>
        <div style="text-align:center"><%= item.quantity %></div>
        <div style="text-align:right;color:#555"><%= fmt_brl(item.unit_price) %></div>
        <div style="text-align:right;font-weight:600"><%= fmt_brl(item.subtotal) %></div>
      </div>
    <% end %>

    <div style="text-align:right;font-size:18px;font-weight:700;color:#6366f1;margin-top:12px">
      Total: <%= fmt_brl(@order.total) %>
    </div>
  </div>

  <!-- Detalhes + ações -->
  <div style="display:flex;flex-direction:column;gap:16px">

    <div class="card">
      <div class="card-title" style="margin-bottom:10px">Informações</div>
      <div style="font-size:14px;display:flex;flex-direction:column;gap:6px">
        <div><span style="color:#888">Cliente:</span> <%= h(@order.customer.to_s.empty? ? '—' : @order.customer) %></div>
        <div><span style="color:#888">Data:</span> <%= @order.created_at.to_s[0,16].gsub('T',' ') %></div>
        <% unless @order.notes.to_s.empty? %>
          <div><span style="color:#888">Obs:</span> <%= h(@order.notes) %></div>
        <% end %>
      </div>
    </div>

    <% if @order.pending? %>
      <div class="card" style="border:2px solid #fbbf24">
        <div style="font-size:13px;color:#92400e;margin-bottom:12px;font-weight:500">
          ⚠ Pedido pendente — o estoque ainda não foi debitado.
        </div>
        <form method="post" action="/orders/<%= @order.id %>/confirm">
          <button class="btn btn-primary" style="width:100%;margin-bottom:8px"
                  onclick="return confirm('Confirmar pedido e debitar estoque?')">
            ✓ Confirmar e Debitar Estoque
          </button>
        </form>
        <form method="post" action="/orders/<%= @order.id %>/cancel">
          <button class="btn btn-danger" style="width:100%"
                  onclick="return confirm('Cancelar este pedido?')">
            ✕ Cancelar Pedido
          </button>
        </form>
      </div>
    <% end %>

    <% if @order.confirmed? %>
      <div class="card" style="border:2px solid #10b981">
        <div style="font-size:13px;color:#065f46;margin-bottom:12px;font-weight:500">
          ✓ Estoque debitado com sucesso.
        </div>
        <form method="post" action="/orders/<%= @order.id %>/cancel">
          <button class="btn btn-ghost" style="width:100%;font-size:13px"
                  onclick="return confirm('Cancelar este pedido e devolver estoque?')">
            Cancelar e Devolver Estoque
          </button>
        </form>
      </div>
    <% end %>

    <% if @order.cancelled? %>
      <div class="card" style="border:2px solid #ef4444">
        <div style="font-size:13px;color:#991b1b;font-weight:500">
          ✕ Pedido cancelado.
        </div>
      </div>
    <% end %>

  </div>
</div>
