<!-- views/audit/index.erb -->
<div class="page-header">
  <div>
    <h1 class="page-title">📋 Logs de Auditoria</h1>
    <p class="page-subtitle">Histórico completo de ações realizadas no sistema</p>
  </div>
  <div class="page-actions">
    <span class="badge badge-info"><%= @total %> registros</span>
  </div>
</div>

<!-- Filtros -->
<div class="card mb-4">
  <form method="GET" action="/audit" class="filter-form">
    <div class="filter-row">
      <div class="form-group">
        <label>Filtrar por Usuário</label>
        <select name="user_id" class="form-control">
          <option value="">Todos os usuários</option>
          <% @users.each do |u| %>
            <option value="<%= u.id %>" <%= 'selected' if @filter_user == u.id.to_s %>>
              <%= h(u.name) %>
            </option>
          <% end %>
        </select>
      </div>
      <div class="form-group">
        <label>Filtrar por Módulo</label>
        <select name="table_name" class="form-control">
          <option value="">Todos os módulos</option>
          <% ['products','categories','movements','orders','users','backups','import','session'].each do |t| %>
            <option value="<%= t %>" <%= 'selected' if @filter_table == t %>>
              <%= AuditLog.new({'table_name'=>t,'action'=>'','user_name'=>''}).table_label %>
            </option>
          <% end %>
        </select>
      </div>
      <div class="form-group" style="align-self:flex-end">
        <button type="submit" class="btn btn-primary">Filtrar</button>
        <a href="/audit" class="btn btn-secondary">Limpar</a>
      </div>
    </div>
  </form>
</div>

<!-- Tabela de logs -->
<div class="card">
  <% if @logs.empty? %>
    <div class="empty-state">
      <span style="font-size:3rem">📋</span>
      <p>Nenhum log encontrado.</p>
    </div>
  <% else %>
    <div class="table-responsive">
      <table class="table">
        <thead>
          <tr>
            <th>Data/Hora</th>
            <th>Usuário</th>
            <th>Ação</th>
            <th>Módulo</th>
            <th>ID</th>
            <th>Detalhes</th>
            <th>IP</th>
          </tr>
        </thead>
        <tbody>
          <% @logs.each do |log| %>
            <tr>
              <td style="white-space:nowrap;font-size:0.85rem">
                <%= log.formatted_date %>
              </td>
              <td><strong><%= h(log.user_name) %></strong></td>
              <td><%= log.action_label %></td>
              <td>
                <span class="badge badge-secondary">
                  <%= log.table_label %>
                </span>
              </td>
              <td><%= log.record_id || '—' %></td>
              <td style="font-size:0.85rem;max-width:300px">
                <%= h(log.details || '—') %>
              </td>
              <td style="font-size:0.8rem;color:var(--muted)">
                <%= h(log.ip || '—') %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Paginação -->
    <% if @pages > 1 %>
      <div class="pagination">
        <% if @page > 1 %>
          <a href="/audit?page=<%= @page - 1 %>" class="btn btn-secondary btn-sm">← Anterior</a>
        <% end %>
        <span style="color:var(--muted);font-size:0.9rem">
          Página <%= @page %> de <%= @pages %>
        </span>
        <% if @page < @pages %>
          <a href="/audit?page=<%= @page + 1 %>" class="btn btn-secondary btn-sm">Próximo →</a>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
