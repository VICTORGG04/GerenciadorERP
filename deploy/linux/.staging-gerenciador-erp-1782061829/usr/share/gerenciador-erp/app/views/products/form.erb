<div class="page-header">
  <h1><%= @product ? 'Editar Produto' : 'Novo Produto' %></h1>
  <a href="/products" class="btn btn-ghost">← Voltar</a>
</div>

<% if @error %>
  <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-weight:500">
    ⚠ <%= @error %>
  </div>
<% end %>

<div class="card" style="max-width:700px">
  <form method="post" action="<%= @product ? "/products/#{@product.id}" : '/products' %>"
        style="display:grid;grid-template-columns:1fr 1fr;gap:14px">

    <div style="grid-column:1/-1">
      <label class="label">Nome *</label>
      <input class="input" name="name"
             value="<%= h(val(:name, @product, @params).to_s) %>" required>
    </div>

    <div>
      <label class="label">SKU *</label>
      <input class="input" name="sku"
             value="<%= h(val(:sku, @product, @params).to_s) %>"
             placeholder="EX-001" required>
    </div>

    <div>
      <label class="label">Categoria</label>
      <select class="input" name="category_id">
        <option value="">— Sem categoria —</option>
        <% selected_cat = (@params&.[]('category_id') || @product&.category_id.to_s) %>
        <% @categories.each do |c| %>
          <option value="<%= c.id %>"
                  <%= selected_cat.to_s == c.id.to_s ? 'selected' : '' %>>
            <%= h(c.name) %>
          </option>
        <% end %>
      </select>
    </div>

    <div>
      <label class="label">Preco de Venda (R$) *</label>
      <input class="input" type="number" step="0.01" name="price"
             value="<%= val(:price, @product, @params) %>" required>
    </div>

    <div>
      <label class="label">Custo (R$)</label>
      <input class="input" type="number" step="0.01" name="cost"
             value="<%= val(:cost, @product, @params) %>">
    </div>

    <% unless @product %>
      <div>
        <label class="label">Quantidade Inicial</label>
        <input class="input" type="number" name="quantity"
               value="<%= @params&.[]('quantity') || 0 %>" min="0">
      </div>
    <% end %>

    <div>
      <label class="label">Estoque Minimo</label>
      <input class="input" type="number" name="min_quantity"
             value="<%= val(:min_quantity, @product, @params) || 5 %>" min="0">
    </div>

    <div>
      <label class="label">Unidade</label>
      <input class="input" name="unit"
             value="<%= h(val(:unit, @product, @params).to_s.then { |v| v.empty? ? 'un' : v }) %>">
    </div>

    <div style="grid-column:1/-1;display:flex;gap:10px;justify-content:flex-end;margin-top:8px">
      <a href="/products" class="btn btn-ghost">Cancelar</a>
      <button class="btn btn-primary" type="submit">Salvar</button>
    </div>

  </form>
</div>
