<!-- views/import/result.erb -->
<div class="page-header">
  <div>
    <h1 class="page-title">📥 Resultado da Importação</h1>
    <p class="page-subtitle">Arquivo: <strong><%= h(@filename) %></strong></p>
  </div>
  <div class="page-actions">
    <a href="/import" class="btn btn-secondary">Nova Importação</a>
    <a href="/products" class="btn btn-primary">Ver Produtos</a>
  </div>
</div>

<!-- Resumo -->
<div class="stats-grid mb-4">
  <div class="stat-card stat-success">
    <div class="stat-value"><%= @result.created %></div>
    <div class="stat-label">✅ Produtos Criados</div>
  </div>
  <div class="stat-card <%= @result.skipped > 0 ? 'stat-warning' : 'stat-secondary' %>">
    <div class="stat-value"><%= @result.skipped %></div>
    <div class="stat-label">⚠️ Ignorados</div>
  </div>
  <div class="stat-card <%= @result.errors.any? ? 'stat-danger' : 'stat-secondary' %>">
    <div class="stat-value"><%= @result.errors.size %></div>
    <div class="stat-label">❌ Erros</div>
  </div>
</div>

<!-- Erros detalhados -->
<% if @result.errors.any? %>
  <div class="card">
    <h3 class="card-title">❌ Erros encontrados</h3>
    <div class="alert alert-warning mb-3" style="font-size:0.85rem">
      Os itens abaixo foram ignorados. Corrija a planilha e importe novamente apenas os que falharam.
    </div>
    <ul style="color:var(--danger);font-size:0.9rem;line-height:2">
      <% @result.errors.each do |err| %>
        <li><%= h(err) %></li>
      <% end %>
    </ul>
  </div>
<% else %>
  <div class="alert alert-success">
    ✅ Importação concluída sem erros!
  </div>
<% end %>
