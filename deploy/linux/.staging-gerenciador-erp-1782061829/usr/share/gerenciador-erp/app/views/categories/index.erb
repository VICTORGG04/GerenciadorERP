<!-- views/categories/index.erb -->
<div class="page-header">
  <h1>Categorias</h1>
  <a href="/" class="btn btn-ghost">← Dashboard</a>
</div>

<% if @error %>
  <div class="alert alert-danger"><%= @error %></div>
<% end %>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start">

  <!-- Lista -->
  <div>
    <% if @categories.empty? %>
      <div class="empty-state">Nenhuma categoria cadastrada.</div>
    <% else %>
      <% @categories.each do |c| %>
        <div class="card" style="border-left:4px solid <%= h(c.color) %>;margin-bottom:12px">
          <div style="display:flex;justify-content:space-between;align-items:center">
            <div>
              <span style="font-weight:600"><%= h(c.name) %></span>
              <span class="text-muted" style="margin-left:8px;font-size:13px">
                <%= c.products_count %> produto(s)
              </span>
            </div>
            <form method="post" action="/categories/<%= c.id %>/delete"
                  onsubmit="return confirm('Excluir categoria <%= h(c.name) %>?')">
              <button class="btn btn-sm btn-danger" type="submit">🗑</button>
            </form>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- Formulário de criação -->
  <div class="card">
    <div class="card-title">+ Nova Categoria</div>
    <form method="post" action="/categories" style="display:flex;flex-direction:column;gap:14px">
      <div>
        <label class="label">Nome *</label>
        <input class="input" name="name" required placeholder="Ex: Eletrônicos">
      </div>
      <div>
        <label class="label">Cor</label>
        <input type="color" name="color" value="#6366f1"
               style="width:50px;height:36px;border:none;border-radius:8px;cursor:pointer">
      </div>
      <button class="btn btn-primary" type="submit">Criar Categoria</button>
    </form>
  </div>

</div>
