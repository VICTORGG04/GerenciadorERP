<!-- views/order.rb/form.erb -->
<div class="page-header">
  <h1>Novo Pedido de Venda</h1>
  <a href="/orders" class="btn btn-ghost">← Voltar</a>
</div>

<% if @error %>
  <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-weight:500">
    ⚠ <%= h(@error) %>
  </div>
<% end %>

<div class="card" style="max-width:800px">
  <form method="post" action="/orders" id="order-form">

    <!-- Dados do pedido -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px">
      <div style="grid-column:1/-1">
        <label class="label">Cliente</label>
        <input class="input" name="customer" placeholder="Nome do cliente (opcional)">
      </div>
      <div style="grid-column:1/-1">
        <label class="label">Observações</label>
        <textarea class="input" name="notes" rows="2" style="resize:vertical" placeholder="Opcional"></textarea>
      </div>
    </div>

    <!-- Itens do pedido -->
    <div style="margin-bottom:16px">
      <div style="font-weight:600;margin-bottom:10px;font-size:15px">Itens</div>

      <div id="items-container">
        <!-- Linha de item template (primeira linha fixa) -->
        <div class="order-item-row" style="display:grid;grid-template-columns:2fr 80px 120px 36px;gap:8px;margin-bottom:8px;align-items:center">
          <select class="input product-select" name="product_id[]" onchange="fillPrice(this)" required>
            <option value="">— Selecione o produto —</option>
            <% @products.each do |p| %>
              <option value="<%= p.id %>"
                      data-price="<%= p.price %>"
                      data-stock="<%= p.quantity %>"
                      <%= p.out_of_stock? ? 'disabled' : '' %>>
                <%= h(p.name) %> (SKU: <%= h(p.sku) %>) — estoque: <%= p.quantity %>
              </option>
            <% end %>
          </select>
          <input class="input" type="number" name="quantity[]" min="1" value="1"
                 placeholder="Qtd" required onchange="updateSubtotal(this)">
          <input class="input" type="number" step="0.01" name="unit_price[]"
                 placeholder="Preço unit." required onchange="updateSubtotal(this)">
          <button type="button" class="btn btn-sm btn-danger" onclick="removeItem(this)" title="Remover">✕</button>
        </div>
      </div>

      <button type="button" class="btn btn-ghost" onclick="addItem()" style="margin-top:4px">
        + Adicionar item
      </button>
    </div>

    <!-- Totalizador -->
    <div style="text-align:right;font-size:18px;font-weight:700;margin-bottom:16px;color:#6366f1">
      Total: <span id="total-display">R$ 0,00</span>
    </div>

    <div style="display:flex;gap:10px;justify-content:flex-end">
      <a href="/orders" class="btn btn-ghost">Cancelar</a>
      <button class="btn btn-primary" type="submit">Criar Pedido</button>
    </div>

  </form>
</div>

<script>
// Dados dos produtos para JS
const products = {
  <% @products.each do |p| %>
    <%= p.id %>: { price: <%= p.price %>, stock: <%= p.quantity %> },
  <% end %>
};

function fillPrice(select) {
  const row   = select.closest('.order-item-row');
  const pid   = select.value;
  const priceInput = row.querySelector('[name="unit_price[]"]');
  if (pid && products[pid]) {
    priceInput.value = products[pid].price.toFixed(2);
    // Limita quantidade ao estoque disponível
    const qtyInput = row.querySelector('[name="quantity[]"]');
    qtyInput.max = products[pid].stock;
  }
  updateTotal();
}

function updateSubtotal(input) {
  updateTotal();
}

function updateTotal() {
  let total = 0;
  document.querySelectorAll('.order-item-row').forEach(row => {
    const qty   = parseFloat(row.querySelector('[name="quantity[]"]').value) || 0;
    const price = parseFloat(row.querySelector('[name="unit_price[]"]').value) || 0;
    total += qty * price;
  });
  document.getElementById('total-display').textContent =
    'R$ ' + total.toFixed(2).replace('.', ',');
}

function addItem() {
  const template = document.querySelector('.order-item-row').cloneNode(true);
  template.querySelector('select').value = '';
  template.querySelector('[name="quantity[]"]').value = 1;
  template.querySelector('[name="unit_price[]"]').value = '';
  document.getElementById('items-container').appendChild(template);
}

function removeItem(btn) {
  const rows = document.querySelectorAll('.order-item-row');
  if (rows.length === 1) return; // mantém ao menos uma linha
  btn.closest('.order-item-row').remove();
  updateTotal();
}
</script>
